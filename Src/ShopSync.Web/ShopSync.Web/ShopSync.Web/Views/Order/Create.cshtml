@model ShopSync.Web.Dtos.CreateOrderRequestDto

@{
    ViewData["Title"] = "Yeni Sipariş Oluştur";
}

<div class="card">
    <div class="card-header">Sipariş Bilgileri</div>
    <div class="card-body">

        <form asp-action="Create" method="post">
            <div class="form-group mb-lg">
                <label class="form-label">Idempotency Key (İsteğe Bağlı)</label>
                <input type="text" asp-for="IdempotencyKey" class="form-input text-mono" placeholder="Örn: req-12345" />
            </div>

            <h3 style="margin-bottom: 10px;">Ürünler</h3>

            <!-- Dinamik Satırlar Buraya Gelecek -->
            <div id="item-rows">
                <div class="form-row flex items-center gap-sm mb-sm item-row">
                    <!-- MVC'nin satır silinmelerinde kafasının karışmaması için gizli INDEX alanı -->
                    <input type="hidden" name="Items.Index" value="0" />

                    <input type="text" name="Items[0].Sku" class="form-input" placeholder="Ürün SKU" required />
                    <input type="number" name="Items[0].Quantity" class="form-input" placeholder="Miktar" required min="1" style="width: 120px;" />
                </div>
            </div>

            <div class="flex gap-sm mt-md">
                <button type="button" class="btn btn-secondary" onclick="addRow()">+ Yeni Kalem Ekle</button>
                <button type="submit" class="btn btn-primary">Siparişi Gönder</button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <script src="~/js/order-create.js" asp-append-version="true"></script>
}