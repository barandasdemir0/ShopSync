@{
    ViewData["Title"] = "Stok İşlemleri";
}

<input type="radio" name="tab" id="tab1" class="tab-radio" checked>
<label for="tab1" class="tab-label">Stok Artır/Azalt</label>

<input type="radio" name="tab" id="tab2" class="tab-radio">
<label for="tab2" class="tab-label">Stok Transfer</label>

<input type="radio" name="tab" id="tab3" class="tab-radio">
<label for="tab3" class="tab-label">Yeni Kalem Oluştur</label>

<input type="radio" name="tab" id="tab4" class="tab-radio">
<label for="tab4" class="tab-label">Kalem Sil</label>

<div class="tab-panels">
    <!-- Tab 1: Stok Artır/Azalt -->
    <div class="tab-panel" data-panel="1">
        <div class="card">
            <div class="card-header">
                Stok Artır veya Azalt
                <span class="text-sm text-muted">POST /api/Inventory/stock/increase veya decrease</span>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Operations">
                    <input type="hidden" name="operation" value="adjust" />
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="adj-sku">SKU Kodu</label>
                            <input type="text" id="adj-sku" name="sku" class="form-input mono" placeholder="orn. ABC-123" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="adj-qty">Miktar</label>
                            <input type="number" id="adj-qty" name="quantity" class="form-input" placeholder="Pozitif: artır, Negatif: azalt" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="adj-warehouse">Depo Kodu</label>
                            <input type="text" id="adj-warehouse" name="warehouseCode" class="form-input" value="DEFAULT" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="adj-reason">Sebep</label>
                            <input type="text" id="adj-reason" name="reason" class="form-input" placeholder="İşlem sebebi" required>
                        </div>
                    </div>
                    <div class="alert alert-info">
                        <strong>Bilgi:</strong> Miktar pozitif ise stok artırılır, negatif ise azaltılır.
                    </div>
                    <button type="submit" class="btn btn-primary"
                            onclick="return confirm('Stok işlemi yapmak istediğinize emin misiniz?')">
                        Stok İşlemini Uygula
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Tab 2: Stok Transfer -->
    <div class="tab-panel" data-panel="2">
        <div class="card">
            <div class="card-header">
                Stok Transfer (Rebalance)
                <span class="text-sm text-muted">POST /api/Inventory/stock/rebalance</span>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Operations">
                    <input type="hidden" name="operation" value="rebalance" />
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="rb-sku">SKU Kodu</label>
                            <input type="text" id="rb-sku" name="sku" class="form-input mono" placeholder="orn. ABC-123" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="rb-qty">Miktar</label>
                            <input type="number" id="rb-qty" name="quantity" class="form-input" min="1" placeholder="Transfer miktarı" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="rb-from">Kaynak Depo</label>
                            <input type="text" id="rb-from" name="fromLocation" class="form-input" placeholder="WH-A" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="rb-to">Hedef Depo</label>
                            <input type="text" id="rb-to" name="toLocation" class="form-input" placeholder="WH-B" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="rb-reason">Sebep</label>
                        <input type="text" id="rb-reason" name="reason" class="form-input" placeholder="Transfer sebebi" required>
                    </div>
                    <button type="submit" class="btn btn-primary"
                            onclick="return confirm('Stok transferi yapmak istediğinize emin misiniz?')">
                        Transfer Uygula
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Tab 3: Yeni Kalem Oluştur -->
    <div class="tab-panel" data-panel="3">
        <div class="card">
            <div class="card-header">
                Yeni Envanter Kalemi Oluştur
                <span class="text-sm text-muted">POST /api/Inventory/item</span>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Operations">
                    <input type="hidden" name="operation" value="create-item" />
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="new-sku">SKU Kodu</label>
                            <input type="text" id="new-sku" name="sku" class="form-input mono" placeholder="orn. ABC-123" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="new-qty">Başlangıç Miktarı</label>
                            <input type="number" id="new-qty" name="initialQuantity" class="form-input" min="0" placeholder="0" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="new-warehouse">Depo Kodu</label>
                            <input type="text" id="new-warehouse" name="warehouseCode" class="form-input" value="DEFAULT" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="new-threshold">Düşük Stok Eşiği</label>
                            <input type="number" id="new-threshold" name="lowStockThreshold" class="form-input" min="0" value="10">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success"
                            onclick="return confirm('Yeni envanter kalemi oluşturmak istediğinize emin misiniz?')">
                        Kalem Oluştur
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Tab 4: Kalem Sil -->
    <div class="tab-panel" data-panel="4">
        <div class="card">
            <div class="card-header">
                Envanter Kalemi Sil
                <span class="text-sm text-muted">DELETE /api/Inventory/item/{warehouseCode}/{sku}</span>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Operations">
                    <input type="hidden" name="operation" value="delete-item" />
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="del-warehouse">Depo Kodu</label>
                            <input type="text" id="del-warehouse" name="warehouseCode" class="form-input" placeholder="DEFAULT" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="del-sku">SKU Kodu</label>
                            <input type="text" id="del-sku" name="sku" class="form-input mono" placeholder="orn. ABC-123" required>
                        </div>
                    </div>
                    <div class="alert alert-danger">
                        <strong>Dikkat:</strong> Bu işlem geri alınamaz! Envanter kalemi kalıcı olarak silinecektir.
                    </div>
                    <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Bu envanter kalemini kalıcı olarak silmek istediğinize emin misiniz?')">
                        Kalemi Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>