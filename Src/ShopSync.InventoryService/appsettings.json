{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://0.0.0.0:5001",
        "Protocols": "Http2"
      },
      "Http": {
        "Url": "http://0.0.0.0:5144",
        "Protocols": "Http1"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "MongoDbSettings": {
    "ConnectionString": "mongodb://127.0.0.1:27017/?replicaSet=rs0",
    "DatabaseName": "shopSync_inventory"
  },
  "RedisSettings": {
    "ConnectionString": "localhost:6379"
  },
  "Loki": {
    "Url": "http://loki:3100"
  },
  "Otlp": {
    "Endpoint": "http://jaeger:4317"
  }
}
