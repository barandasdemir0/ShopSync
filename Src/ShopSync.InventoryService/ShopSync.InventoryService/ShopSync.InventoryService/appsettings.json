{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  //Sonradan Eklenen Yapılar
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  // docker ortamında isimleriyle haberleşilir
  "Loki": {
    "Url": "http://loki:3100"
  },
  "Otlp": {
    "Endpoint": "http://jaeger:4317"
  }

}
