{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },

  "Loki": {
    "Url": "http://loki:3100"
  },
  "Otlp": {
    "Endpoint": "http://jaeger:4317"
  },
  "RateLimiting": {
    "PermitLimit": 100, // Belirtilen zaman aralığında izin verilen maksimum istek sayısı
    "WindowSeconds": 60, // Zaman aralığı (saniye cinsinden)
    "QueueLimit": 5 // bu süreçte bekleyen isteklerin maksimum sayısı
  }
}
